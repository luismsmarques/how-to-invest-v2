{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "660px",
			"wideSize": "1100px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"custom": true,
			"customGradient": false,
			"palette": [
				{
					"slug": "base",
					"color": "#ffffff",
					"name": "Base"
				},
				{
					"slug": "surface",
					"color": "#f6f8f7",
					"name": "Surface"
				},
				{
					"slug": "contrast",
					"color": "#14241d",
					"name": "Text"
				},
				{
					"slug": "muted",
					"color": "#5b6b64",
					"name": "Muted text"
				},
				{
					"slug": "border",
					"color": "#dde5e1",
					"name": "Border"
				},
				{
					"slug": "primary",
					"color": "#1b7a5a",
					"name": "Primary green"
				},
				{
					"slug": "primary-hover",
					"color": "#145c44",
					"name": "Primary green (hover)"
				},
				{
					"slug": "secondary",
					"color": "#e7f2ed",
					"name": "Soft green"
				},
				{
					"slug": "info",
					"color": "#2a6f97",
					"name": "Info"
				},
				{
					"slug": "info-surface",
					"color": "#eaf2f7",
					"name": "Info surface"
				},
				{
					"slug": "caution",
					"color": "#8a5a00",
					"name": "Caution"
				},
				{
					"slug": "caution-surface",
					"color": "#fbf3e2",
					"name": "Caution surface"
				}
			]
		},
		"typography": {
			"fluid": true,
			"defaultFontSizes": false,
			"customFontSize": true,
			"lineHeight": true,
			"writingMode": false,
			"dropCap": false,
			"fontFamilies": [
				{
					"slug": "sans",
					"name": "Sans (system)",
					"fontFamily": "system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji'"
				},
				{
					"slug": "serif",
					"name": "Serif (system)",
					"fontFamily": "Iowan Old Style, 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"name": "Small",
					"size": "0.875rem",
					"fluid": false
				},
				{
					"slug": "medium",
					"name": "Medium",
					"size": "1.125rem",
					"fluid": {
						"min": "1.0625rem",
						"max": "1.1875rem"
					}
				},
				{
					"slug": "large",
					"name": "Large",
					"size": "1.375rem",
					"fluid": {
						"min": "1.25rem",
						"max": "1.5rem"
					}
				},
				{
					"slug": "x-large",
					"name": "Extra large",
					"size": "1.875rem",
					"fluid": {
						"min": "1.625rem",
						"max": "2.125rem"
					}
				},
				{
					"slug": "xx-large",
					"name": "Extra extra large",
					"size": "2.625rem",
					"fluid": {
						"min": "2.125rem",
						"max": "3rem"
					}
				}
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"customSpacingSize": true,
			"units": [ "px", "em", "rem", "vh", "vw", "%" ],
			"spacingSizes": [
				{
					"slug": "20",
					"name": "1",
					"size": "clamp(0.75rem, 1.5vw, 1rem)"
				},
				{
					"slug": "30",
					"name": "2",
					"size": "clamp(1rem, 2vw, 1.5rem)"
				},
				{
					"slug": "40",
					"name": "3",
					"size": "clamp(1.5rem, 3vw, 2.25rem)"
				},
				{
					"slug": "50",
					"name": "4",
					"size": "clamp(2.25rem, 5vw, 3.5rem)"
				},
				{
					"slug": "60",
					"name": "5",
					"size": "clamp(3.5rem, 7vw, 5rem)"
				},
				{
					"slug": "70",
					"name": "6",
					"size": "clamp(5rem, 9vw, 7rem)"
				}
			]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"dimensions": {
			"minHeight": true
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--sans)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.7"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--30)",
			"padding": {
				"top": "0",
				"right": "var(--wp--preset--spacing--30)",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--30)"
			}
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary-hover)"
					}
				},
				":focus": {
					"outline": {
						"color": "var(--wp--preset--color--primary)",
						"style": "solid",
						"width": "2px"
					}
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--sans)",
					"fontWeight": "700",
					"lineHeight": "1.25"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--base)"
				},
				"border": {
					"radius": "8px"
				},
				"spacing": {
					"padding": {
						"top": "0.75rem",
						"right": "1.5rem",
						"bottom": "0.75rem",
						"left": "1.5rem"
					}
				},
				"typography": {
					"fontWeight": "600"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--primary-hover)",
						"text": "var(--wp--preset--color--base)"
					}
				},
				":focus": {
					"outline": {
						"color": "var(--wp--preset--color--primary-hover)",
						"style": "solid",
						"width": "2px"
					}
				}
			}
		},
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "700"
				}
			},
			"core/post-title": {
				"typography": {
					"lineHeight": "1.2"
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--border)"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	],
	"customTemplates": [
		{
			"name": "page-no-sidebar",
			"title": "Page (full width, no header padding)",
			"postTypes": [ "page" ]
		}
	]
}
