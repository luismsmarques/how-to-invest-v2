{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "680px",
			"wideSize": "1280px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"custom": true,
			"customGradient": true,
			"palette": [
				{
					"slug": "background",
					"color": "#FFF6F1",
					"name": "Background (cream)"
				},
				{
					"slug": "white",
					"color": "#ffffff",
					"name": "White"
				},
				{
					"slug": "contrast",
					"color": "#2A2438",
					"name": "Text"
				},
				{
					"slug": "body-alt",
					"color": "#3A3450",
					"name": "Body alt"
				},
				{
					"slug": "muted",
					"color": "#6E6680",
					"name": "Muted text"
				},
				{
					"slug": "muted-light",
					"color": "#767189",
					"name": "Muted light"
				},
				{
					"slug": "border",
					"color": "#F2E4DD",
					"name": "Border"
				},
				{
					"slug": "primary",
					"color": "#FF6B5E",
					"name": "Coral"
				},
				{
					"slug": "primary-strong",
					"color": "#C9362C",
					"name": "Coral (AA text/buttons)"
				},
				{
					"slug": "primary-hover",
					"color": "#FF5544",
					"name": "Coral (hover)"
				},
				{
					"slug": "primary-soft",
					"color": "#FFEDE9",
					"name": "Coral soft"
				},
				{
					"slug": "accent",
					"color": "#7C5CFC",
					"name": "Purple"
				},
				{
					"slug": "accent-soft",
					"color": "#EFE9FE",
					"name": "Purple soft"
				},
				{
					"slug": "accent-border",
					"color": "#E7DCFB",
					"name": "Purple border"
				},
				{
					"slug": "caution",
					"color": "#D69A1E",
					"name": "Caution"
				},
				{
					"slug": "caution-surface",
					"color": "#FFF3D6",
					"name": "Caution surface"
				},
				{
					"slug": "success",
					"color": "#22C3A6",
					"name": "Green"
				},
				{
					"slug": "success-surface",
					"color": "#E6F7EF",
					"name": "Green surface"
				},
				{
					"slug": "dark",
					"color": "#2A2438",
					"name": "Dark"
				},
				{
					"slug": "navy",
					"color": "#1E2147",
					"name": "Navy"
				}
			],
			"gradients": [
				{
					"slug": "coral-soft",
					"name": "Coral soft",
					"gradient": "linear-gradient(135deg, #FFEDE9, #FFD9D2)"
				},
				{
					"slug": "green-soft",
					"name": "Green soft",
					"gradient": "linear-gradient(135deg, #E6F7EF, #D2E8DC)"
				},
				{
					"slug": "gold-soft",
					"name": "Gold soft",
					"gradient": "linear-gradient(135deg, #F6EEDD, #EFE2C5)"
				}
			]
		},
		"typography": {
			"fluid": true,
			"defaultFontSizes": false,
			"customFontSize": true,
			"lineHeight": true,
			"writingMode": false,
			"dropCap": false,
			"fontFamilies": [
				{
					"slug": "body",
					"name": "Plus Jakarta Sans",
					"fontFamily": "'Plus Jakarta Sans', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
					"fontFace": [
						{
							"fontFamily": "Plus Jakarta Sans",
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/plus-jakarta-sans-400.woff2" ]
						},
						{
							"fontFamily": "Plus Jakarta Sans",
							"fontWeight": "500",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/plus-jakarta-sans-500.woff2" ]
						},
						{
							"fontFamily": "Plus Jakarta Sans",
							"fontWeight": "600",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/plus-jakarta-sans-600.woff2" ]
						},
						{
							"fontFamily": "Plus Jakarta Sans",
							"fontWeight": "700",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/plus-jakarta-sans-700.woff2" ]
						}
					]
				},
				{
					"slug": "heading",
					"name": "Poppins",
					"fontFamily": "'Poppins', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
					"fontFace": [
						{
							"fontFamily": "Poppins",
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/poppins-400.woff2" ]
						},
						{
							"fontFamily": "Poppins",
							"fontWeight": "500",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/poppins-500.woff2" ]
						},
						{
							"fontFamily": "Poppins",
							"fontWeight": "600",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/poppins-600.woff2" ]
						},
						{
							"fontFamily": "Poppins",
							"fontWeight": "700",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/poppins-700.woff2" ]
						},
						{
							"fontFamily": "Poppins",
							"fontWeight": "800",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/poppins-800.woff2" ]
						}
					]
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"name": "Small",
					"size": "0.875rem",
					"fluid": false
				},
				{
					"slug": "medium",
					"name": "Medium",
					"size": "1.0625rem",
					"fluid": {
						"min": "1rem",
						"max": "1.125rem"
					}
				},
				{
					"slug": "large",
					"name": "Large",
					"size": "1.375rem",
					"fluid": {
						"min": "1.25rem",
						"max": "1.5rem"
					}
				},
				{
					"slug": "x-large",
					"name": "Extra large",
					"size": "2rem",
					"fluid": {
						"min": "1.625rem",
						"max": "2.25rem"
					}
				},
				{
					"slug": "xx-large",
					"name": "Extra extra large",
					"size": "2.75rem",
					"fluid": {
						"min": "2.125rem",
						"max": "3.25rem"
					}
				},
				{
					"slug": "huge",
					"name": "Huge (hero)",
					"size": "4rem",
					"fluid": {
						"min": "2.375rem",
						"max": "4.25rem"
					}
				}
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"customSpacingSize": true,
			"units": [ "px", "em", "rem", "vh", "vw", "%" ],
			"spacingSizes": [
				{
					"slug": "20",
					"name": "1",
					"size": "clamp(0.75rem, 1.5vw, 1rem)"
				},
				{
					"slug": "30",
					"name": "2",
					"size": "clamp(1rem, 2vw, 1.5rem)"
				},
				{
					"slug": "40",
					"name": "3",
					"size": "clamp(1.5rem, 3vw, 2.25rem)"
				},
				{
					"slug": "50",
					"name": "4",
					"size": "clamp(2.25rem, 5vw, 3.5rem)"
				},
				{
					"slug": "60",
					"name": "5",
					"size": "clamp(3.5rem, 7vw, 5rem)"
				},
				{
					"slug": "70",
					"name": "6",
					"size": "clamp(5rem, 9vw, 7rem)"
				}
			]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"dimensions": {
			"minHeight": true
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.55"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--30)",
			"padding": {
				"top": "0",
				"right": "clamp(1.25rem, 4vw, 2rem)",
				"bottom": "0",
				"left": "clamp(1.25rem, 4vw, 2rem)"
			}
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary-strong)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary-hover)"
					}
				},
				":focus": {
					"outline": {
						"color": "var(--wp--preset--color--primary)",
						"style": "solid",
						"width": "2.5px"
					}
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "700",
					"lineHeight": "1.12",
					"letterSpacing": "-0.02em"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"letterSpacing": "-0.01em"
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary-strong)",
					"text": "var(--wp--preset--color--white)"
				},
				"border": {
					"radius": "12px"
				},
				"spacing": {
					"padding": {
						"top": "0.9rem",
						"right": "1.75rem",
						"bottom": "0.9rem",
						"left": "1.75rem"
					}
				},
				"typography": {
					"fontWeight": "600"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--primary-hover)",
						"text": "var(--wp--preset--color--white)"
					}
				},
				":focus": {
					"outline": {
						"color": "var(--wp--preset--color--primary)",
						"style": "solid",
						"width": "2.5px"
					}
				}
			}
		},
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontSize": "1.125rem",
					"fontWeight": "600",
					"letterSpacing": "-0.02em"
				}
			},
			"core/post-title": {
				"typography": {
					"lineHeight": "1.1"
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--border)"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	],
	"customTemplates": [
		{
			"name": "page-no-sidebar",
			"title": "Page (full width, no header padding)",
			"postTypes": [ "page" ]
		},
		{
			"name": "page-about",
			"title": "About page",
			"postTypes": [ "page" ]
		}
	]
}
